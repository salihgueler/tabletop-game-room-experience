{
  "name": "tabletop-game-room-experience",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "aws-blocks"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev:server": "tsx watch aws-blocks/scripts/server.ts",
    "dev:client": "vite",
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "sandbox": "tsx aws-blocks/scripts/sandbox.ts",
    "sandbox:destroy": "tsx -C cdk aws-blocks/scripts/sandbox-destroy.ts",
    "sandbox:console": "tsx aws-blocks/scripts/console.ts",
    "cleanup": "tsx aws-blocks/scripts/cleanup.ts",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "tsx aws-blocks/scripts/deploy.ts",
    "destroy": "tsx aws-blocks/scripts/destroy.ts"
  },
  "dependencies": {
    "@aws-blocks/blocks": "*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "aws-cdk-lib": "^2.257.0",
    "concurrently": "^8.2.0",
    "constructs": "^10.6.0",
    "esbuild": "^0.27.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vite": "^5.4.11"
  }
}
